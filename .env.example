# Required
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/partitions
ENCRYPTION_KEY=<run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# Optional — defaults shown
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
DB_ECHO=false

# Webhook URL for alert notifications (stuck-disarmed, NVR offline, auto-rearm)
ALERT_WEBHOOK_URL=https://your-webhook-endpoint/alerts

# Interval in seconds for the stuck-disarmed monitor job (default: 300 = 5 minutes). Wired to stuck_disarmed_monitor scheduler.
POLL_INTERVAL_SECONDS=300
